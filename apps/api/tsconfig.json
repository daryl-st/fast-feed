{
    "extends": "@repo/typescript-config/api.json",
    "compilerOptions": {
        "strict": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "target": "ESNext",
        "module": "ESNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "bundler",
        "paths": {
            "@/*": ["./src/*"],
        },
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
